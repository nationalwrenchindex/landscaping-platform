# Copy this file to .env.local and fill in the values for the NEW landscaping
# Supabase / Stripe / Twilio / etc. projects. Do NOT reuse NWI Suite credentials.

# ── Supabase (new landscaping project) — Project Settings > API ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App base URL (used in email/SMS links) ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI ──
GEMINI_API_KEY=your-gemini-key-here          # Field Assist (or GOOGLE_GEMINI_API_KEY)
ANTHROPIC_API_KEY=your-anthropic-key-here

# ── SMS (Twilio) ──
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Billing (Stripe) ──
STRIPE_SECRET_KEY=sk_live_or_test_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key

# ── Email (Resend) ──
RESEND_API_KEY=your-resend-key-here

# ── Founder SMS alerts (optional) ──
BROCK_PHONE_NUMBER=+1xxxxxxxxxx
